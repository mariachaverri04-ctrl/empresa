<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Información Personal</title>
    <link rel="stylesheet" href="styles.css" />
</head>
<body class="page">
    <main class="profile">
        <section class="card">
            <header class="card__header">
                <h1 class="card__title">Información Personal</h1>
                <p class="card__subtitle">Perfil académico y personal</p>
            </header>

            <div class="info-list">
                <article class="info-item">
                    <h2 class="info-item__title">Nombre</h2>
                    <p class="info-item__text">Maria Chaverri cAMPOS</p>
                </article>

                <article class="info-item">
                    <h2 class="info-item__title">De dónde es</h2>
                    <p class="info-item__text">Acosta</p>
                </article>

                <article class="info-item">
                    <h2 class="info-item__title">Carrera</h2>
                    <p class="info-item__text">Ingeniería en Sistemas</p>
                </article>

                <article class="info-item">
                    <h2 class="info-item__title">Residencia</h2>
                    <p class="info-item__text">BN-1</p>
                </article>
            </div>
        </section>
    </main>
</body>
</html>
